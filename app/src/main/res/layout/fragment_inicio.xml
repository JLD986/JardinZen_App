<?xml version="1.0" encoding="utf-8"?>


<!--
Diseño del FragmentInicio: esta vista muestra un saludo al usuario y su jardín personal.
Contiene un título principal, un subtítulo y una lista de plantas mostradas con un RecyclerView.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/beige_claro"
    tools:context="com.example.jardnzen_app.Fragmentos.FragmentInicio">

    <!-- Contenedor principal con orientación vertical -->
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="5dp">

        <!-- Título principal que da la bienvenida al usuario -->
        <TextView
            android:id="@+id/hola_usuario"
            android:text="@string/hola_usuario"
            android:fontFamily="@font/comfortaa"
            android:textStyle="bold"
            android:textColor="@color/verde_fuente"
            android:layout_marginTop="20dp"
            android:layout_marginLeft="20dp"
            android:textSize="40sp"
            android:layout_width="250dp"
            android:layout_height="60dp"/>

        <!-- Subtítulo que identifica la sección "Mi Jardín" -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="20dp">

            <TextView
                android:id="@+id/mi_jardin"
                android:text="@string/mi_jardin"
                android:fontFamily="@font/comfortaa"
                android:textStyle="bold"
                android:textSize="27sp"
                android:textColor="@color/verde_fuente2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <ImageButton
                android:id="@+id/btn_agregar_planta"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/blanco_redondeado"
                android:src="@android:drawable/ic_input_add"
                android:layout_marginEnd="10dp"
                android:contentDescription="Agregar planta" />

            <ImageButton
                android:id="@+id/btn_borrar_planta"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/blanco_redondeado"
                android:src="@android:drawable/ic_delete"
                android:contentDescription="Borrar planta" />

        </LinearLayout>

        <!-- Lista de plantas del jardín mostradas mediante un RecyclerView.
             Cada elemento se representa con el diseño "target_planta". -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_jardin"
            android:layout_marginTop="20dp"
            android:clipToPadding="false"
            android:layout_gravity="center"
            android:layout_width="390dp"
            android:layout_height="match_parent"
            tools:listitem="@layout/target_planta"/>

    </LinearLayout>

</FrameLayout>
