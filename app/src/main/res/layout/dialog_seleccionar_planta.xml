<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/beige_claro">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Selecciona tu planta"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/verde_oscuro"
        android:fontFamily="@font/comfortaa"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/et_buscar_planta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Buscar planta (ej: Aloe)..."
        android:padding="12dp"
        android:background="@drawable/card_border"
        android:fontFamily="@font/comfortaa"
        android:layout_marginBottom="12dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_almanaque"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginBottom="12dp"/>

    <LinearLayout
        android:id="@+id/layout_sugerir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿No encuentras tu planta?"
            android:fontFamily="@font/comfortaa"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_sugerir_planta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sugerir planta"
            app:backgroundTint="@color/verde_oscuro"
            android:fontFamily="@font/comfortaa"/>
    </LinearLayout>

</LinearLayout>
